# Sensitive data — never commit
*.mmdb
*.key
wireguard-vps.conf
config/wireguard-vps.conf

# Live capture data — too large for GitHub, contains real attacker IPs
# Sync to data/live/ locally using scp from Ubuntu Server
data/live/*.json
data/live/*.log
data/live/*.csv
# Keep the directory itself tracked
!data/live/.gitkeep

# Large log files — use data/sample/ instead
/opt/cowrie-logs/

# GeoIP databases
*.tar.gz
GeoLite2-*/

# Python
__pycache__/
*.py[cod]
*.egg-info/
.venv/
venv/
dist/
build/
*.egg

# Jupyter
.ipynb_checkpoints/
*.ipynb

# OS
.DS_Store
Thumbs.db
*.swp
*.swo

# Editor
.vscode/
.idea/
*.sublime-project
*.sublime-workspace

# Credentials
.env
*.env
secrets.yaml
credentials.json

# Compiled outputs
*.pyc

data/live/*.gz
data/live/*.json
data/live/*.mmdb
data/live/*.log
